{
  "name": "midas-intranet-backend",
  "version": "2.0.0",
  "description": "Enterprise Backend for MIDAS Intranet",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:security": "jest tests/security.test.js",
    "backup": "node backup.js",
    "backup:db": "node backup-database.js",
    "preflight": "node preflight.js",
    "hash:passwords": "node hashPasswords.js",
    "migrate": "node migrations/run.js",
    "production": "npm run preflight && NODE_ENV=production node server.js"
  },
  "keywords": [
    "intranet",
    "midas",
    "enterprise"
  ],
  "author": "Jorddy",
  "license": "PROPRIETARY",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.10.3",
    "nodemailer": "^7.0.11",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4"
  }
}
